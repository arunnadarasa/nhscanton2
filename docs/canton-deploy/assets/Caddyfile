{
  email {$ACME_EMAIL}
}

{$PUBLIC_HOSTNAME} {
  encode zstd gzip
  reverse_proxy canton:7575 {
    # v2 has no /livez; use a cheap JSON API endpoint as the upstream probe.
    health_uri /v2/state/ledger-end
    health_interval 10s
  }
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
    X-Content-Type-Options "nosniff"
  }
}
